<group name="cowrie,">

  <rule id="100010" level="3">
    <field name="eventid">^cowrie\.</field>
    <description>Cowrie honeypot event detected</description>
  </rule>

  <rule id="100011" level="5">
    <if_sid>100010</if_sid>
    <field name="eventid">^cowrie\.login\.failed$</field>
    <description>Cowrie honeypot: failed login attempt</description>
  </rule>

  <rule id="100012" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100011</if_matched_sid>
    <description>Cowrie honeypot: possible brute-force attack from single IP</description>
  </rule>

  <rule id="100013" level="7">
    <if_sid>100010</if_sid>
    <field name="eventid">^cowrie\.login\.success$</field>
    <description>Cowrie honeypot: attacker successfully logged in</description>
  </rule>

  <rule id="100014" level="12">
    <if_sid>100010</if_sid>
    <field name="eventid">^cowrie\.command\.input$</field>
    <description>Cowrie honeypot: attacker executed a command</description>
  </rule>

</group>
